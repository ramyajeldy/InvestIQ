@"
# Environment variables - NEVER commit this
.env

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/

# Node
node_modules/
dist/
.next/

# Chroma local DB
chroma_db/

# Data (raw local copies)
data/bronze/*
data/silver/*
data/gold/*
!data/bronze/.gitkeep
!data/silver/.gitkeep
!data/gold/.gitkeep

# OS
.DS_Store
Thumbs.db
"@ | Set-Content .gitignore